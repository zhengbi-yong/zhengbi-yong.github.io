# Release metadata
COMPOSE_PROJECT_NAME=blog-platform
APP_RUNTIME_ENVIRONMENT=production
APP_VERSION=1.8.2
VCS_REF=main
BUILD_DATE=2026-03-22T00:00:00Z

# Images
# Use immutable version tags from the release workflow in production.
# For local builds, override these with blog-backend:local and blog-frontend:local.
BACKEND_IMAGE=ghcr.io/your-org/your-repo/blog-backend:1.8.2
FRONTEND_IMAGE=ghcr.io/your-org/your-repo/blog-frontend:1.8.2
POSTGRES_IMAGE=postgres:17-alpine
REDIS_IMAGE=redis:7.4-alpine
MEILISEARCH_IMAGE=getmeili/meilisearch:v1.12
MINIO_IMAGE=minio/minio:RELEASE.2025-02-28T09-55-16Z
EDGE_IMAGE=nginx:1.27-alpine
MAILPIT_IMAGE=axllent/mailpit:v1.27

# Public routing
NEXT_PUBLIC_SITE_URL=https://blog.example.com
# Leave these empty when using the edge proxy and same-origin /api routing.
NEXT_PUBLIC_BACKEND_URL=
NEXT_PUBLIC_API_URL=
BACKEND_INTERNAL_URL=http://api:3000
CORS_ALLOWED_ORIGINS=https://blog.example.com
ENABLE_EDGE_PROXY=true
ENABLE_BUNDLED_MEILISEARCH=false
ENABLE_BUNDLED_MINIO=false
ENABLE_BUNDLED_MAILPIT=false

# Published ports
EDGE_BIND_HOST=0.0.0.0
FRONTEND_BIND_HOST=127.0.0.1
BACKEND_BIND_HOST=127.0.0.1
POSTGRES_BIND_HOST=127.0.0.1
REDIS_BIND_HOST=127.0.0.1
MEILISEARCH_BIND_HOST=127.0.0.1
MINIO_BIND_HOST=127.0.0.1
MAILPIT_BIND_HOST=127.0.0.1
FRONTEND_PORT=3001
BACKEND_PORT=3000
POSTGRES_PORT=5432
REDIS_PORT=6379
MEILISEARCH_PORT=7700
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
EDGE_HTTP_PORT=80
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

# Core secrets
POSTGRES_USER=blog_user
POSTGRES_PASSWORD=replace-with-a-strong-database-password
POSTGRES_DB=blog_db
REDIS_PASSWORD=replace-with-a-strong-redis-password
JWT_SECRET=replace-with-a-32-byte-jwt-secret
PASSWORD_PEPPER=replace-with-a-separate-32-byte-password-pepper

# SMTP (required by backend runtime)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=noreply@example.com
SMTP_PASSWORD=replace-with-smtp-password
SMTP_FROM=noreply@example.com
SMTP_TLS=true

# Runtime
RUST_LOG=info
DATABASE_POOL_MAX_CONNECTIONS=20
DATABASE_POOL_MIN_CONNECTIONS=5
DATABASE_POOL_ACQUIRE_TIMEOUT_SECS=10
DATABASE_POOL_MAX_LIFETIME_SECS=1800
DATABASE_POOL_IDLE_TIMEOUT_SECS=600
REDIS_POOL_MAX_SIZE=10
REDIS_POOL_WAIT_TIMEOUT_SECS=5
REDIS_POOL_CREATE_TIMEOUT_SECS=5
REDIS_POOL_RECYCLE_TIMEOUT_SECS=5
WORKER_POLL_INTERVAL_SECS=5
WORKER_BATCH_SIZE=100
WORKER_LOCK_TIMEOUT_SECS=300
HEALTH_OUTBOX_PENDING_WARN_THRESHOLD=1000
HEALTH_OUTBOX_PENDING_FAIL_THRESHOLD=5000
HEALTH_OUTBOX_OLDEST_WARN_SECS=60
HEALTH_OUTBOX_OLDEST_FAIL_SECS=300

# Rate limiting
RATE_LIMIT_AUTH_RPS=5
RATE_LIMIT_AUTH_RPM=100
RATE_LIMIT_VIEW_RPS=10
RATE_LIMIT_VIEW_RPM=1000
RATE_LIMIT_COMMENT_RPS=2
RATE_LIMIT_COMMENT_RPM=20
RATE_LIMIT_DEFAULT_RPS=100
RATE_LIMIT_DEFAULT_RPM=6000
RATE_LIMIT_FAILURE_MODE=fail_open

# Search (leave blank to disable, enable `search` profile to run bundled Meilisearch)
MEILISEARCH_URL=
MEILISEARCH_MASTER_KEY=
MEILISEARCH_INDEX=posts
MEILISEARCH_AUTO_SYNC=false

# Storage
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=/app/uploads
STORAGE_LOCAL_URL=/uploads
MINIO_ENDPOINT=
MINIO_PUBLIC_URL=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=
MINIO_REGION=us-east-1

# Frontend observability
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENABLED=false
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_RELEASE=1.8.2
# Optional: only needed for build-time release creation and source map upload.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
FRONTEND_OTEL_ENABLED=false
FRONTEND_OTEL_EXPORTER_OTLP_ENDPOINT=
FRONTEND_OTEL_SERVICE_NAME=blog-frontend
FRONTEND_OTEL_SERVICE_VERSION=1.8.2

# Backend observability
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=blog-api
OTEL_SERVICE_VERSION=1.8.2
