# =============================================================================
# Production Environment Variables
# =============================================================================

# Database Configuration
POSTGRES_USER=blog_user
POSTGRES_PASSWORD=CHANGE_THIS_SECURE_PASSWORD
POSTGRES_DB=blog_db

# Redis Configuration
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD

# JWT Configuration (Generate a secure secret at least 256 bits)
JWT_SECRET=GENERATE_A_SECURE_JWT_SECRET_HERE

# Server Configuration
HOST=0.0.0.0
PORT=3000

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@domain.com
SMTP_PASSWORD=your-app-password

# Environment
RUST_LOG=info
ENVIRONMENT=production

# Security (Generate secure values)
PASSWORD_PEPPER=GENERATE_A_SECURE_PEPPER_HERE
CORS_ORIGIN=https://yourdomain.com

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Session Configuration
SESSION_SECRET=GENERATE_A_SECURE_SESSION_SECRET_HERE
SESSION_TIMEOUT_HOURS=24

# File Upload Configuration
MAX_FILE_SIZE_MB=10
UPLOAD_PATH=./uploads

# Monitoring and Analytics
SENTRY_DSN=YOUR_SENTRY_DSN_HERE
PROMETHEUS_ENABLED=true

# OpenAPI Configuration
API_TITLE=Blog API
API_VERSION=1.0.0
API_DESCRIPTION=A backend API for the blog platform