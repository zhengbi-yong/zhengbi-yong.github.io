# 部署服务器配置示例
# 复制此文件为 .env.deploy 并填入实际值
# ⚠️ 警告：.env.deploy 包含敏感信息，不要提交到 Git！

# SSH 服务器配置
DEPLOY_REMOTE_USER=ubuntu
DEPLOY_REMOTE_IP=152.136.43.194
DEPLOY_REMOTE_PORT=22
DEPLOY_REMOTE_PATH=/home/ubuntu/PersonalBlog/out/

# SSH 密钥路径（推荐方式）
DEPLOY_SSH_KEY=~/.ssh/id_rsa

# SSH 密码（如果使用密码认证，不推荐）
# DEPLOY_SSH_PASSWORD=your_password_here
