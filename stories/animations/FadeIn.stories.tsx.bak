import type { Meta, StoryObj } from '@storybook/nextjs'
import FadeIn from '@/components/animations/FadeIn'

const meta: Meta<typeof FadeIn> = {
  title: 'Animations/FadeIn',
  component: FadeIn,
  parameters: {
    layout: 'centered',
  },
  tags: ['autodocs'],
  argTypes: {
    duration: {
      control: { type: 'range', min: 0.1, max: 3, step: 0.1 },
    },
    delay: {
      control: { type: 'range', min: 0, max: 2, step: 0.1 },
    },
    direction: {
      control: 'select',
      options: ['up', 'down', 'left', 'right', 'none'],
    },
    distance: {
      control: { type: 'range', min: 0, max: 100, step: 10 },
    },
  },
}

export default meta
type Story = StoryObj<typeof meta>

// Default fade in
export const Default: Story = {
  args: {
    children: (
      <div className="p-8 bg-blue-500 text-white rounded-lg">
        <h2 className="text-xl font-bold">Fade In Animation</h2>
        <p className="mt-2">This content fades in when mounted.</p>
      </div>
    ),
  },
}

// Custom duration
export const SlowFade: Story = {
  args: {
    duration: 2,
    children: (
      <div className="p-8 bg-green-500 text-white rounded-lg">
        <h2 className="text-xl font-bold">Slow Fade In (2s)</h2>
        <p className="mt-2">This content fades in slowly over 2 seconds.</p>
      </div>
    ),
  },
}

// With delay
export const DelayedFade: Story = {
  args: {
    delay: 1,
    children: (
      <div className="p-8 bg-purple-500 text-white rounded-lg">
        <h2 className="text-xl font-bold">Delayed Fade In (1s delay)</h2>
        <p className="mt-2">This content fades in after a 1 second delay.</p>
      </div>
    ),
  },
}

// Fade from bottom
export const FadeFromBottom: Story = {
  args: {
    direction: 'up',
    distance: 50,
    children: (
      <div className="p-8 bg-orange-500 text-white rounded-lg">
        <h2 className="text-xl font-bold">Fade In from Bottom</h2>
        <p className="mt-2">This content fades in and slides up from 50px below.</p>
      </div>
    ),
  },
}

// Fade from left
export const FadeFromLeft: Story = {
  args: {
    direction: 'left',
    distance: 100,
    children: (
      <div className="p-8 bg-red-500 text-white rounded-lg">
        <h2 className="text-xl font-bold">Fade In from Left</h2>
        <p className="mt-2">This content fades in and slides in from 100px to the left.</p>
      </div>
    ),
  },
}

// Staggered animations
export const Staggered: Story = {
  render: () => (
    <div className="space-y-4">
      <FadeIn delay={0}>
        <div className="p-4 bg-blue-500 text-white rounded">First (0s delay)</div>
      </FadeIn>
      <FadeIn delay={0.2}>
        <div className="p-4 bg-blue-600 text-white rounded">Second (0.2s delay)</div>
      </FadeIn>
      <FadeIn delay={0.4}>
        <div className="p-4 bg-blue-700 text-white rounded">Third (0.4s delay)</div>
      </FadeIn>
      <FadeIn delay={0.6}>
        <div className="p-4 bg-blue-800 text-white rounded">Fourth (0.6s delay)</div>
      </FadeIn>
    </div>
  ),
}

// Complex content
export const ComplexContent: Story = {
  args: {
    children: (
      <div className="max-w-md bg-white dark:bg-gray-800 rounded-lg shadow-lg overflow-hidden">
        <img
          src="https://picsum.photos/400/200"
          alt="Example image"
          className="w-full h-48 object-cover"
        />
        <div className="p-6">
          <div className="flex items-center gap-2 mb-2">
            <span className="px-2 py-1 bg-blue-100 dark:bg-blue-900 text-blue-800 dark:text-blue-200 text-xs rounded">
              Animation
            </span>
            <span className="px-2 py-1 bg-green-100 dark:bg-green-900 text-green-800 dark:text-green-200 text-xs rounded">
              Interactive
            </span>
          </div>
          <h3 className="text-xl font-bold text-gray-900 dark:text-white mb-2">
            Animated Card Component
          </h3>
          <p className="text-gray-600 dark:text-gray-400 mb-4">
            This entire card component fades in smoothly when it appears on screen. The animation includes all content elements.
          </p>
          <button className="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 transition-colors">
            Learn More
          </button>
        </div>
      </div>
    ),
  },
}