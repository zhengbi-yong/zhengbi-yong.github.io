import type { Meta, StoryObj } from '@storybook/nextjs'
import { useEffect, useState } from 'react'
import { useReadingProgress } from '@/components/hooks/useReadingProgress'

const meta: Meta = {
  title: 'Hooks/useReadingProgress',
  parameters: {
    layout: 'fullscreen',
    docs: {
      description: {
        component: 'A hook that tracks reading progress for articles or scrollable content.',
      },
    },
  },
  tags: ['autodocs'],
}

export default meta
type Story = StoryObj<typeof meta>

// Demo component
function ReadingProgressDemo({ height }: { height: number }) {
  const { progress, isReading, readingTime, isAtBottom } = useReadingProgress()

  return (
    <div className="h-screen flex flex-col">
      {/* Progress bar at top */}
      <div className="fixed top-0 left-0 right-0 h-1 bg-gray-200 dark:bg-gray-700 z-50">
        <div
          className="h-full bg-blue-600 transition-all duration-300"
          style={{ width: `${progress}%` }}
        />
      </div>

      {/* Stats display */}
      <div className="fixed top-4 right-4 bg-white dark:bg-gray-800 p-4 rounded-lg shadow-lg z-40">
        <h3 className="font-semibold mb-2">Reading Progress</h3>
        <div className="space-y-1 text-sm">
          <p>Progress: {Math.round(progress)}%</p>
          <p>Reading: {isReading ? 'Yes' : 'No'}</p>
          <p>Time: {Math.round(readingTime)}s</p>
          <p>At bottom: {isAtBottom ? 'Yes' : 'No'}</p>
        </div>
      </div>

      {/* Content */}
      <div className="flex-1 overflow-y-auto p-8" style={{ height: `${height}px` }}>
        <h1 className="text-3xl font-bold mb-6">Sample Article</h1>
        <div className="space-y-4 max-w-3xl">
          {Array.from({ length: 30 }, (_, i) => (
            <p key={i} className="text-gray-700 dark:text-gray-300 leading-relaxed">
              Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.
              Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat.
              Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur.
              Excepteur sint occaecat cupidatat non proident, sunt in culpa qui officia deserunt mollit anim id est laborum.
              Sed ut perspiciatis unde omnis iste natus error sit voluptatem accusantium doloremque laudantium.
            </p>
          ))}
        </div>
      </div>
    </div>
  )
}

// Basic usage
export const Default: Story = {
  render: () => <ReadingProgressDemo height={600} />,
}

// Tall content
export const TallContent: Story = {
  render: () => <ReadingProgressDemo height={1200} />,
  parameters: {
    docs: {
      description: {
        story: 'Example with very tall content to see progress tracking over a longer scroll.',
      },
    },
  },
}

// Short content
export const ShortContent: Story = {
  render: () => <ReadingProgressDemo height={400} />,
  parameters: {
    docs: {
      description: {
        story: 'Example with short content that fits within viewport without scrolling.',
      },
    },
  },
}