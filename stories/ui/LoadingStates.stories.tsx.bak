// Table Skeleton
export const DefaultTableSkeleton: Story = {
  render: () => <TableSkeleton rows={5} columns={4} />,
}

export const LargeTableSkeleton: Story = {
  render: () => <TableSkeleton rows={10} columns={6} />,
}

// Empty State
export const DefaultEmptyState: Story = {
  render: () => (
    <EmptyState
      title="No data found"
      description="Try adjusting your search or filters to find what you're looking for."
    />
  ),
}

export const EmptyStateWithIcon: Story = {
  render: () => (
    <EmptyState
      icon={
        <svg className="w-12 h-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={1.5} d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
      }
      title="No users found"
      description="We couldn't find any users matching your search criteria."
      action={
        <button className="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700">
          Create New User
        </button>
      }
    />
  ),
}

