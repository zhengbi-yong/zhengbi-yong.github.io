# Database Configuration
DATABASE_URL=postgresql://blog_user:blog_password@localhost:5432/blog_db

# Redis Configuration
REDIS_URL=redis://localhost:6379

# JWT Configuration (generate a secure secret, at least 256 bits)
JWT_SECRET=your-super-secret-jwt-key-here-make-it-at-least-256-bits

# Server Configuration
HOST=127.0.0.1
PORT=3000

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Environment
RUST_LOG=info
ENVIRONMENT=development

# Security
PASSWORD_PEPPER=your-password-pepper-here
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Session Configuration
SESSION_SECRET=your-session-secret-here
SESSION_TIMEOUT_HOURS=24

# File Upload Configuration
MAX_FILE_SIZE_MB=10
UPLOAD_PATH=./uploads

# Storage Configuration (local or minio)
# Options: local, minio
STORAGE_BACKEND=local

# Local Storage Settings (used when STORAGE_BACKEND=local)
STORAGE_LOCAL_PATH=/app/uploads
STORAGE_LOCAL_URL=/uploads

# MinIO Settings (used when STORAGE_BACKEND=minio)
# For local development with docker-compose:
# MINIO_ENDPOINT=http://localhost:9000
# MINIO_PUBLIC_URL=http://localhost:9000
# For production, use your MinIO instance URL
MINIO_ENDPOINT=http://minio:9000
MINIO_PUBLIC_URL=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=blog-uploads
MINIO_REGION=us-east-1

# Monitoring and Analytics
SENTRY_DSN=your-sentry-dsn-here
PROMETHEUS_ENABLED=true
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_MASTER_KEY=change-me-in-production
MEILISEARCH_INDEX=posts
MEILISEARCH_AUTO_SYNC=true

# OpenAPI Configuration
API_TITLE=Blog API
API_VERSION=1.0.0
API_DESCRIPTION=A backend API for the blog platform
