      "post": {
        "tags": [
          "posts"
        ],
        "summary": "记录文章浏览",
        "operationId": "view",
        "parameters": [
          {
            "name": "slug",
            "in": "path",
            "description": "文章slug",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "浏览记录成功"
          },
          "404": {
            "description": "文章不存在"
          },
          "429": {
            "description": "限流"
          }
        }
      }
    },
    "/readyz": {
      "get": {
        "tags": [
          "monitoring"
        ],
        "operationId": "readyz",
