          "user": {
            "$ref": "#/components/schemas/UserInfo"
          }
        }
      },
      "DatabasePoolStatus": {
        "type": "object",
        "required": [
          "size",
          "idle",
          "active"
        ],
        "properties": {
          "active": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "idle": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "size": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          }
        }
      },
