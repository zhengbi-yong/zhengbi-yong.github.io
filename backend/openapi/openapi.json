      "get": {
        "tags": [
          "search"
        ],
        "summary": "搜索建议（自动补全）",
        "operationId": "search_suggest",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "description": "搜索关键词",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "返回数量（默认5，最大10）",
