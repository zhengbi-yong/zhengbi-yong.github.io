          "monitoring"
        ],
        "operationId": "health_detailed",
        "responses": {
          "200": {
            "description": "服务健康",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DetailedHealth"
                }
              }
            }
          },
          "503": {
            "description": "服务不健康"
          }
        }
