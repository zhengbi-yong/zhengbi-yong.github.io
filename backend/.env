# Database Configuration
DATABASE_URL=postgresql://blog_user:blog_password@localhost:5432/blog_db

# Redis Configuration
REDIS_URL=redis://localhost:6379

# JWT Configuration (至少32字符)
JWT_SECRET=dev-secret-key-for-testing-only-make-it-at-least-256-bits-long
PASSWORD_PEPPER=dev-password-pepper-for-testing-32chars

# Server Configuration
SERVER_HOST=127.0.0.1
SERVER_PORT=3000
HOST=127.0.0.1
PORT=3000

# SMTP Configuration (开发环境使用localhost)
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USERNAME=dev@example.com
SMTP_PASSWORD=dev-password
SMTP_FROM=noreply@example.com
SMTP_TLS=true

# Environment
RUST_LOG=debug
ENVIRONMENT=development

# CORS Configuration (允许本地开发)
CORS_ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3000,http://localhost:3002,http://localhost:3003
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
CORS_ALLOWED_HEADERS=Authorization,Content-Type,Accept,X-Requested-With
CORS_ORIGIN=http://localhost:3000

# Rate Limiting (开发环境宽松限制)
RATE_LIMIT_AUTH_RPS=10
RATE_LIMIT_AUTH_RPM=1000
RATE_LIMIT_VIEW_RPS=100
RATE_LIMIT_VIEW_RPM=10000
RATE_LIMIT_COMMENT_RPS=10
RATE_LIMIT_COMMENT_RPM=500
RATE_LIMIT_DEFAULT_RPS=1000
RATE_LIMIT_DEFAULT_RPM=60000
RATE_LIMIT_PER_MINUTE=1000

# Session Configuration
SESSION_SECRET=dev-session-secret-key-for-testing-32chars
SESSION_TIMEOUT_HOURS=24

# Prometheus Monitoring
PROMETHEUS_ENABLED=true

# OpenAPI Configuration
API_TITLE="Blog API"
API_VERSION=1.0.0
API_DESCRIPTION="A backend API for the blog platform"
