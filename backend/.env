# Database Configuration
DATABASE_URL=postgresql://blog_user:blog_password@localhost:5432/blog_db

# Redis Configuration
REDIS_URL=redis://localhost:6379

# JWT Configuration
JWT_SECRET=dev-secret-key-for-testing-only-32-chars

# Server Configuration
HOST=127.0.0.1
PORT=3000

# Environment
RUST_LOG=debug
ENVIRONMENT=development

# Security
PASSWORD_PEPPER=dev-pepper

# CORS Configuration
# Frontend runs on port 3001 by default (Next.js dev server)
CORS_ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3000,http://localhost:3002,http://localhost:3003
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
CORS_ALLOWED_HEADERS=Authorization,Content-Type,Accept

# Rate Limiting
RATE_LIMIT_PER_MINUTE=1000

# Session Configuration
SESSION_SECRET=dev-session-secret
SESSION_TIMEOUT_HOURS=24

# Monitoring
PROMETHEUS_ENABLED=true

# SMTP Configuration (for email notifications - not required for dev)
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USERNAME=dev@example.com
SMTP_PASSWORD=dev-password
SMTP_FROM=noreply@example.com
SMTP_TLS=false
