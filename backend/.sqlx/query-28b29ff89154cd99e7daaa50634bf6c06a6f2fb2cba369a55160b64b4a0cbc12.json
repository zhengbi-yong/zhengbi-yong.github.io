{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT\n                c.id,\n                c.slug,\n                c.user_id,\n                c.parent_id,\n                c.content,\n                c.html_sanitized,\n                c.status as \"status: blog_db::CommentStatus\",\n                c.path,\n                c.depth,\n                c.like_count,\n                c.created_at,\n                c.updated_at,\n                c.deleted_at,\n                c.created_ip,\n                c.user_agent,\n                c.moderation_reason,\n                u.username,\n                u.profile as \"profile: _\"\n            FROM comments c\n            JOIN users u ON c.user_id = u.id\n            WHERE c.slug = $1 AND c.status = $2\n            ORDER BY c.created_at DESC\n            LIMIT $3\n            ",
