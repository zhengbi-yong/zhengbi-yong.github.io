  "query": "\n                SELECT t.id, t.slug, t.name\n                FROM tags t\n                JOIN post_tags pt ON t.id = pt.tag_id\n                JOIN posts p ON pt.post_id = p.id\n                WHERE p.slug = $1\n                ",
