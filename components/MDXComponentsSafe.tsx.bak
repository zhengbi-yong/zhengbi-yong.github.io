import dynamic from 'next/dynamic'
import { Suspense } from 'react'
import TOCInline from 'pliny/ui/TOCInline'
import Pre from 'pliny/ui/Pre'
import BlogNewsletterForm from 'pliny/ui/BlogNewsletterForm'
import type { MDXComponents } from 'mdx/types'
import Image from './Image'
import CustomLink from './Link'
import TableWrapper from './TableWrapper'
import AnimatedSection from './AnimatedSection'
import AnimatedList from './AnimatedList'
import { AnimationSkeleton } from './loaders/AnimationSkeleton'
import { AnimationErrorBoundary } from './AnimationErrorBoundary'
import { sanitizeHtml } from '@/lib/security/sanitize'

// 安全的包装器组件
function SafeWrapper({ children, ...props }: { children: React.ReactNode; [key: string]: any }) {
  // 清理 props，防止注入
  const cleanProps = Object.entries(props).reduce((acc, [key, value]) => {
    // 只允许安全的属性
    if (typeof value === 'string') {
      acc[key] = sanitizeHtml(value, { isMdx: true })
    } else if (typeof value === 'object' && value !== null) {
      // 对于对象属性，进行深度检查
      acc[key] = value
    } else {
      acc[key] = value
    }
    return acc
  }, {} as Record<string, any>)

  return <>{children}</>
}

// 动态导入动画组件，减少初始 bundle 大小
const FadeIn = dynamic(() => import('./animations/FadeIn').then((mod) => mod.default), {
  loading: () => <AnimationSkeleton />,
})

const SlideIn = dynamic(() => import('./animations/SlideIn').then((mod) => mod.default), {
  loading: () => <AnimationSkeleton />,
})

const ScaleIn = dynamic(() => import('./animations/ScaleIn').then((mod) => mod.default), {
  loading: () => <AnimationSkeleton />,
})

const RotateIn = dynamic(() => import('./animations/RotateIn').then((mod) => mod.default), {
  loading: () => <AnimationSkeleton />,
})

const BounceIn = dynamic(() => import('./animations/BounceIn').then((mod) => mod.default), {
  loading: () => <AnimationSkeleton />,
})

const ConfettiOnView = dynamic(
  () => import('./animations/ConfettiOnView').then((mod) => mod.default),
  {
    loading: () => null,
  }
)

// 动态导入乐谱组件
const MusicSheet = dynamic(() => import('./MusicSheet').then((mod) => mod.default), {
  loading: () => (
    <div className="my-6 flex h-64 items-center justify-center rounded-lg border border-dashed border-gray-200 dark:border-gray-700">
      <div className="flex flex-col items-center gap-3">
        <div className="border-t-primary-500 h-8 w-8 animate-spin rounded-full border-4 border-gray-300" />
        <p className="text-sm text-gray-500 dark:text-gray-400">正在加载乐谱组件...</p>
      </div>
    </div>
  ),
})

// 安全的动态导入组件
const SafeDynamicImport = (componentImport: () => Promise<{ default: any }>) => {
  const Component = dynamic(componentImport, {
    loading: () => <AnimationSkeleton />,
    // ssr: false 对于需要客户端环境的组件
  })

  // 返回带安全检查的包装组件
  return (props: any) => (
    <SafeWrapper {...props}>
      <AnimationErrorBoundary>
        <Suspense fallback={<AnimationSkeleton />}>
          <Component {...props} />
        </Suspense>
      </AnimationErrorBoundary>
    </SafeWrapper>
  )
}

// 包装动画组件，添加错误边界和 Suspense
const WrappedFadeIn = SafeDynamicImport(() => import('./animations/FadeIn'))
const WrappedSlideIn = SafeDynamicImport(() => import('./animations/SlideIn'))
const WrappedScaleIn = SafeDynamicImport(() => import('./animations/ScaleIn'))
const WrappedRotateIn = SafeDynamicImport(() => import('./animations/RotateIn'))
const WrappedBounceIn = SafeDynamicImport(() => import('./animations/BounceIn'))

const WrappedConfettiOnView = (props: any) => (
  <SafeWrapper {...props}>
    <AnimationErrorBoundary>
      <Suspense fallback={null}>
        <ConfettiOnView {...props} />
      </Suspense>
    </AnimationErrorBoundary>
  </SafeWrapper>
)

// 安全的自定义组件
const SafeCustomLink = ({ href, children, ...props }: any) => {
  // 验证 href
  if (href && typeof href === 'string') {
    // 检查危险协议
    if (href.startsWith('javascript:') || href.startsWith('data:') || href.startsWith('vbscript:')) {
      console.warn('Dangerous href detected:', href)
      return <span>{children}</span> // 降级为 span
    }
  }

  return (
    <SafeWrapper {...props}>
      <CustomLink href={href} {...props}>
        {children}
      </CustomLink>
    </SafeWrapper>
  )
}

// 安全的图片组件
const SafeImage = ({ src, alt, ...props }: any) => {
  // 验证图片源
  if (src && typeof src === 'string') {
    // 只允许 http, https, data: 协议
    if (!src.startsWith('http:') && !src.startsWith('https:') && !src.startsWith('data:')) {
      console.warn('Invalid image src:', src)
      return <div className="inline-block">[图片加载失败]</div>
    }
  }

  // 确保有 alt 文本
  if (!alt) {
    console.warn('Image missing alt text:', src)
  }

  return (
    <SafeWrapper {...props}>
      <Image src={src} alt={alt || ''} {...props} />
    </SafeWrapper>
  )
}

// 安全的表格包装器
const SafeTableWrapper = ({ children, ...props }: any) => {
  return (
    <SafeWrapper {...props}>
      <TableWrapper {...props}>
        {children}
      </TableWrapper>
    </SafeWrapper>
  )
}

// 安全的代码块
const SafePre = ({ children, ...props }: any) => {
  // 检查代码内容中的潜在危险
  if (typeof children === 'string') {
    // 检查是否包含危险模式
    const dangerousPatterns = [
      /javascript:/gi,
      /data:text\/html/gi,
      /<script/gi,
      /on\w+\s*=/gi,
    ]

    const hasDanger = dangerousPatterns.some(pattern => pattern.test(children))
    if (hasDanger) {
      console.warn('Potentially dangerous code block detected')
    }
  }

  return (
    <SafeWrapper {...props}>
      <Pre {...props}>
        {children}
      </Pre>
    </SafeWrapper>
  )
}

// 安全的 TOC
const SafeTOCInline = ({ toc, ...props }: any) => {
  // 验证 TOC 数据
  if (toc && Array.isArray(toc)) {
    const safeToc = toc.map(item => ({
      ...item,
      title: typeof item.title === 'string' ? sanitizeText(item.title) : item.title,
    }))
    return <TOCInline toc={safeToc} {...props} />
  }

  return <TOCInline toc={toc} {...props} />
}

// 简单的文本清理函数
function sanitizeText(text: string): string {
  return text
    .replace(/[\x00-\x1F\x7F]/g, '')
    .replace(/[<>]/g, '')
    .trim()
}

export const components: MDXComponents = {
  Image: SafeImage,
  TOCInline: SafeTOCInline,
  a: SafeCustomLink,
  pre: SafePre,
  table: SafeTableWrapper,
  BlogNewsletterForm,
  // 第一阶段动画组件（向后兼容）
  AnimatedSection: (props: any) => (
    <SafeWrapper {...props}>
      <AnimatedSection {...props} />
    </SafeWrapper>
  ),
  AnimatedList: (props: any) => (
    <SafeWrapper {...props}>
      <AnimatedList {...props} />
    </SafeWrapper>
  ),
  // Framer Motion 动画组件（动态导入，按需加载，带错误边界）
  FadeIn: WrappedFadeIn,
  SlideIn: WrappedSlideIn,
  ScaleIn: WrappedScaleIn,
  RotateIn: WrappedRotateIn,
  BounceIn: WrappedBounceIn,
  ConfettiOnView: WrappedConfettiOnView,
  // 乐谱组件（动态导入，按需加载）
  MusicSheet: (props: any) => (
    <SafeWrapper {...props}>
      <AnimationErrorBoundary>
        <Suspense fallback={<AnimationSkeleton />}>
          <MusicSheet {...props} />
        </Suspense>
      </AnimationErrorBoundary>
    </SafeWrapper>
  ),
}