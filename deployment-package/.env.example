# 博客系统生产环境配置
# 请修改以下配置后重命名为 .env

# ==================== 数据库配置 ====================
POSTGRES_USER=blog_user
POSTGRES_PASSWORD=blog_password_change_this
POSTGRES_DB=blog_db
POSTGRES_PORT=5432

# ==================== Redis 配置 ====================
REDIS_PORT=6379

# ==================== 后端配置 ====================
BACKEND_PORT=3000
RUST_LOG=info

# ==================== 前端配置 ====================
FRONTEND_PORT=3001
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://your-domain.com

# ==================== 安全配置 (必须修改!) ====================
# JWT 密钥 (至少32位随机字符串)
JWT_SECRET=change-this-to-a-random-minimum-32-characters-string

# 密码加密盐 (至少32位随机字符串)
PASSWORD_PEPPER=change-this-to-another-random-32-characters-string

# 会话密钥 (至少32位随机字符串)
SESSION_SECRET=change-this-to-a-third-random-32-characters-string

# ==================== CORS 配置 ====================
# 允许的前端域名 (逗号分隔)
CORS_ALLOWED_ORIGINS=http://localhost:3001,https://your-domain.com

# ==================== 限流配置 ====================
RATE_LIMIT_PER_MINUTE=60

# ==================== 邮件配置 (可选) ====================
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
