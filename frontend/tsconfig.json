{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noUncheckedIndexedAccess": false,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "incremental": true,
    "module": "esnext",
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@/components/*": [
        "./src/components/*"
      ],
      "@/components/features/*": [
        "./src/components/features/*"
      ],
      "@/components/ui/*": [
        "./src/components/ui/*"
      ],
      "@/components/layouts/*": [
        "./src/components/layouts/*"
      ],
      "@/components/shared/*": [
        "./src/components/shared/*"
      ],
      "@/lib/*": [
        "./src/lib/*"
      ],
      "@/lib/hooks/*": [
        "./src/lib/hooks/*"
      ],
      "@/lib/store/*": [
        "./src/lib/store/*"
      ],
      "@/lib/utils/*": [
        "./src/lib/utils/*"
      ],
      "@/lib/types/*": [
        "./src/lib/types/*"
      ],
      "@/data/*": [
        "./data/*"
      ],
      "@/styles/*": [
        "./src/styles/*"
      ],
      "@/config/*": [
        "./src/config/*"
      ],
      "contentlayer/generated": [
        "./src/lib/contentlayer/generated.ts"
      ],
      "pliny/*": [
        "node_modules/pliny/*"
      ],
      "pliny/utils/contentlayer": [
        "./src/lib/pliny/utils/contentlayer.ts"
      ],
      "pliny/mdx-components": [
        "./src/lib/pliny/mdx-components.tsx"
      ],
      "three/examples/jsm/*": [
        "node_modules/three/examples/jsm/*"
      ]
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "noEmit": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.js",
    "**/*.mjs",
    "**/*.ts",
    "**/*.tsx",
    "**/*.json",
    ".velite/**/*.json",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    ".next/dev/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "public/chemistry",
    "src/payload",
    "src/examples/**/*",
    "src/components/performance/**/*",
    "src/lib/performance/**/*",
    "**/tests/**",
    "**/vitest.config.ts",
    "eslint.config.mjs",
    "e2e/**/*"
  ]
}
