import { Payload } from 'payload'
import config from '../payload.config'

let cachedPayload: Payload | null = null

interface Args {
  initCacheOnly?: boolean
}

/**
 * Payload 客户端初始化
 * 用于在服务端和客户端访问 Payload API
 */
export const getPayload = async ({ initCacheOnly = false }: Args = {}): Promise<Payload> => {
  if (!cachedPayload) {
    cachedPayload = await payload.init({
      config,
      // 仅在需要时初始化缓存
      initCacheOnly,
      // 可以在这里添加其他初始化选项
    })
  }

  return cachedPayload
}

// 导出 payload 实例，供直接使用
import { payload } from 'payload'
export { payload }
