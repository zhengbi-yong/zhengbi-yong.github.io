  // Admin 面板配置
  admin: {
    user: Users.slug,
    build: {
      outputDir: path.resolve(__dirname, 'build/admin'),
    },
    // 自定义 Admin 路由路径（避免与现有 admin 冲突）
    adminRoute: '/payload-admin',
    // 可以自定义 Admin 面板的主题和组件
