# OpenTelemetry Configuration
# Enable OpenTelemetry tracing
OTEL_ENABLED=false

# Base OTLP endpoint for trace export (e.g., Jaeger, Tempo, Honeycomb).
# @vercel/otel will append /v1/traces automatically when OTEL_EXPORTER_OTLP_ENDPOINT is used.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Optional: Override only the trace endpoint instead of using the base endpoint above.
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces

# Optional: OTLP transport protocol. @vercel/otel defaults to http/protobuf.
# OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# Optional: Add custom headers for authentication
# These headers are read directly by @vercel/otel.
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Bearer YOUR_TOKEN

# Service metadata overrides
OTEL_SERVICE_NAME=blog-frontend
OTEL_SERVICE_NAMESPACE=frontend

# Service version override (default: from package.json)
OTEL_SERVICE_VERSION=1.0.0

# Meilisearch Configuration
# Enable Meilisearch search
NEXT_PUBLIC_MEILISEARCH_ENABLED=false

# Meilisearch endpoint
NEXT_PUBLIC_MEILISEARCH_URL=http://localhost:7700

# Meilisearch API key (if using hosted instance)
# MEILISEARCH_API_KEY=your-api-key-here

# Search index name
NEXT_PUBLIC_MEILISEARCH_INDEX=blog_posts
