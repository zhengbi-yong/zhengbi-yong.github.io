# ================================
# 博客系统Docker环境变量配置
# ================================
# 复制此文件为 .env 并填写实际值
# 命令: cp .env.docker.example .env

# ================================
# 数据库配置
# ================================
POSTGRES_USER=blog_user
POSTGRES_PASSWORD=your_secure_postgres_password_here
POSTGRES_DB=blog_db
POSTGRES_PORT=5432

# ================================
# Redis配置
# ================================
REDIS_PORT=6379

# ================================
# 后端API配置
# ================================
BACKEND_PORT=3000
RUST_LOG=info

# 安全配置（必须修改！）
# 生成方法: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_at_least_32_characters_long_change_this
PASSWORD_PEPPER=your_password_pepper_at_least_32_characters_change_this
SESSION_SECRET=your_session_secret_at_least_32_characters_change_this

# CORS配置（允许的前端域名）
CORS_ALLOWED_ORIGINS=http://localhost:3001,https://zhengbi-yong.top

# 限流配置
RATE_LIMIT_PER_MINUTE=60

# 邮件配置（可选）
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_email_app_password
SMTP_FROM=noreply@zhengbi-yong.top

# ================================
# 前端配置
# ================================
FRONTEND_PORT=3001
NEXT_PUBLIC_SITE_URL=http://localhost
NEXT_PUBLIC_API_URL=http://localhost:3000

# ================================
# 监控配置（可选）
# ================================
# 启用Prometheus监控
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# Grafana仪表盘
GRAFANA_PORT=3002
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_ROOT_URL=http://localhost:3000

# ================================
# 生产环境额外配置
# ================================
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_UMAMI_ID=your-umami-id
# SENTRY_DSN=your-sentry-dsn
# ENVIRONMENT=production
