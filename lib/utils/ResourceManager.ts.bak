/**
 * 资源管理器 - 用于防止内存泄漏
 * 管理动画帧、事件监听器、Three.js 对象等资源
 */

export class ResourceManager {
  private animationFrameIds: Set<number> = new Set()
  private eventListeners: Map<Element, Array<{ event: string; handler: EventListener; options?: boolean | AddEventListenerOptions }>> = new Map()
  private intervals: Set<NodeJS.Timeout> = new Set()
  private timeouts: Set<NodeJS.Timeout> = new Set()
  private threeObjects: Set<any> = new Set()
  private observers: Set<{ disconnect(): void }> = new Set()

  // 动画帧管理
  requestAnimationFrame(callback: FrameRequestCallback): number {
    const id = requestAnimationFrame(callback)
    this.animationFrameIds.add(id)
    return id
  }

  cancelAnimationFrame(id: number): void {
    cancelAnimationFrame(id)
    this.animationFrameIds.delete(id)
  }

  // 事件监听器管理
  addEventListener<T extends keyof HTMLElementEventMap>(
    element: HTMLElement,
    event: T,
    handler: (ev: HTMLElementEventMap[T]) => any,
    options?: boolean | AddEventListenerOptions
  ): void {
    element.addEventListener(event, handler, options)

    if (!this.eventListeners.has(element)) {
      this.eventListeners.set(element, [])
    }

    this.eventListeners.get(element)!.push({ event: event as string, handler, options })
  }

  // 定时器管理
  setInterval(callback: () => void, delay: number): NodeJS.Timeout {
    const id = setInterval(callback, delay)
    this.intervals.add(id)
    return id
  }

  clearInterval(id: NodeJS.Timeout): void {
    clearInterval(id)
    this.intervals.delete(id)
  }

  setTimeout(callback: () => void, delay: number): NodeJS.Timeout {
    const id = setTimeout(callback, delay)
    this.timeouts.add(id)
    return id
  }

  clearTimeout(id: NodeJS.Timeout): void {
    clearTimeout(id)
    this.timeouts.delete(id)
  }

  // Three.js 对象管理
  registerThreeObject(object: any): void {
    this.threeObjects.add(object)
  }

  // 观察者管理 (IntersectionObserver, ResizeObserver 等)
  registerObserver(observer: { disconnect(): void }): void {
    this.observers.add(observer)
  }

  // 清理所有资源
  dispose(): void {
    // 取消所有动画帧
    this.animationFrameIds.forEach(id => cancelAnimationFrame(id))
    this.animationFrameIds.clear()

    // 移除所有事件监听器
    this.eventListeners.forEach((listeners, element) => {
      listeners.forEach(({ event, handler, options }) => {
        element.removeEventListener(event, handler, options)
      })
    })
    this.eventListeners.clear()

    // 清除所有定时器
    this.intervals.forEach(id => clearInterval(id))
    this.intervals.clear()

    this.timeouts.forEach(id => clearTimeout(id))
    this.timeouts.clear()

    // 释放 Three.js 对象
    this.threeObjects.forEach(object => {
      if (object && typeof object.dispose === 'function') {
        object.dispose()
      } else if (object && object.geometry) {
        // Three.js Mesh
        if (object.geometry) object.geometry.dispose()
        if (object.material) {
          if (Array.isArray(object.material)) {
            object.material.forEach(material => material.dispose())
          } else {
            object.material.dispose()
          }
        }
      }
    })
    this.threeObjects.clear()

    // 断开所有观察者
    this.observers.forEach(observer => observer.disconnect())
    this.observers.clear()
  }

  // 获取资源统计（调试用）
  getStats() {
    return {
      animationFrames: this.animationFrameIds.size,
      eventListeners: Array.from(this.eventListeners.values()).reduce((sum, arr) => sum + arr.length, 0),
      intervals: this.intervals.size,
      timeouts: this.timeouts.size,
      threeObjects: this.threeObjects.size,
      observers: this.observers.size,
    }
  }
}

// Hook for React 组件
export function useResourceManager() {
  const resourceManagerRef = React.useRef<ResourceManager | null>(null)

  React.useEffect(() => {
    resourceManagerRef.current = new ResourceManager()

    return () => {
      if (resourceManagerRef.current) {
        resourceManagerRef.current.dispose()
        resourceManagerRef.current = null
      }
    }
  }, [])

  return resourceManagerRef.current
}

// 全局资源管理器实例（用于非组件场景）
export const globalResourceManager = new ResourceManager()